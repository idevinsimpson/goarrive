rules_version = '2';

// GoArrive Firestore Security Rules
// Blueprint v1.5 (approved March 11, 2026)
// Patched March 17, 2026 — added isCoachByUid() bootstrap fallback
// for accounts where custom claims (role, coachId, tenantId) have not yet
// been set by Cloud Functions. This allows the app to function fully
// before the Cloud Functions claim-assignment flow is deployed.
//
// CONSTRAINT: No app-layer-only masking for sensitive data.
// All privacy enforcement is at the rules layer.
// Encourager access to journals is blocked here — not in the app.

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function getRole() {
      return request.auth.token.role;
    }

    function getCoachId() {
      return request.auth.token.coachId;
    }

    function getTenantId() {
      return request.auth.token.tenantId;
    }

    function isPlatformAdmin() {
      return isAuthenticated() && (getRole() == 'platformAdmin' || request.auth.token.admin == true);
    }

    function isCoach() {
      return isAuthenticated() && getRole() == 'coach';
    }

    function isOwnDoc(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isOwnTenant(coachId) {
      return isAuthenticated() && getTenantId() == coachId;
    }

    function isCoachOfTenant(coachId) {
      return isAuthenticated() && getRole() == 'coach' && getCoachId() == coachId;
    }

    // Bootstrap fallback: allows a user whose UID matches the coachId field
    // to act as coach even before custom claims are set by Cloud Functions.
    // This is safe because it only grants access to documents the user owns.
    function isCoachByUid(coachId) {
      return isAuthenticated() && request.auth.uid == coachId;
    }

    // Combined coach check: custom claims OR uid-based bootstrap
    function isCoachOrBootstrap(coachId) {
      return isCoachOfTenant(coachId) || isCoachByUid(coachId);
    }

    // ─────────────────────────────────────────────
    // USERS
    // ─────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isOwnDoc(uid) || isPlatformAdmin() || isCoachOfTenant(resource.data.coachId) || isCoachByUid(resource.data.coachId);
      allow create: if isPlatformAdmin(); // Cloud Functions create via Admin SDK
      // Users can update their own safe profile fields (displayName, phone, photoURL).
      // Role, coachId, tenantId, and other system fields are only writable by Cloud Functions
      // via the Admin SDK (which bypasses these rules entirely).
      allow update: if isPlatformAdmin()
                    || (isOwnDoc(uid)
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['displayName', 'phone', 'photoURL', 'updatedAt', 'fcmToken']));
      allow delete: if false; // never delete users

      // FCM push tokens — users can manage their own device tokens
      match /fcmTokens/{tokenId} {
        allow read, write: if isOwnDoc(uid);
      }
    }

    // ─────────────────────────────────────────────
    // COACHES (Cloud Functions write via Admin SDK)
    // Coaches read their own doc; used by AuthContext to determine role.
    // ─────────────────────────────────────────────

    match /coaches/{coachId} {
      // Public list for coach selection on intake page; get requires auth
      allow list: if true;
      allow get: if isOwnDoc(coachId) || isPlatformAdmin();
      // Coaches can update their own scheduling settings
      allow update: if isOwnDoc(coachId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['noShowGraceMinutes', 'autoApproveSkipCategories', 'autoApproveSkipLeadDays', 'icalToken']);
      allow create, delete: if false; // Cloud Functions only (Admin SDK)

      // Slot templates — coach manages their own templates
      match /slot_templates/{templateId} {
        allow read: if isOwnDoc(coachId) || isPlatformAdmin();
        allow create, update: if isOwnDoc(coachId) || isPlatformAdmin();
        allow delete: if isOwnDoc(coachId) || isPlatformAdmin();
      }
    }

    // ─────────────────────────────────────────────
    // SHARED TEMPLATES (Item 4: cross-coach template sharing)
    // ─────────────────────────────────────────────
    match /shared_templates/{templateId} {
      allow read: if isAuthenticated() && (isCoach() || isPlatformAdmin());
      allow create: if isAuthenticated() && (isCoach() || isPlatformAdmin());
      allow delete: if isPlatformAdmin() || (isCoach() && resource.data.sharedBy == getCoachId());
    }

    // ─────────────────────────────────────────────
    // COACH BRANDS
    // ─────────────────────────────────────────────

    match /coach_brands/{coachId} {
      allow read: if isOwnDoc(coachId) || isPlatformAdmin() || isOwnTenant(coachId) || isCoachByUid(coachId);
      allow create: if isOwnDoc(coachId) || isPlatformAdmin();
      allow update: if isOwnDoc(coachId) || isPlatformAdmin();
      // Computed fields (activeMemberCount, currentTier, etc.) are written by Cloud Functions only
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // MEMBER PLANS
    // ─────────────────────────────────────────────

    match /member_plans/{planId} {
      // get: full document-level check (resource.data available).
      // Three principals are allowed:
      //   1. The member who owns the plan (memberId matches their uid)
      //   2. The coach who owns the plan (coachId matches via isCoachOrBootstrap)
      //   3. A platform admin
      // The (resource == null) guard handles the case where the document does not
      // yet exist — Firestore evaluates get rules even for non-existent docs, and
      // resource.data would be null, causing isCoachOrBootstrap to throw. When the
      // document is absent, only a coach (by UID bootstrap) or admin may proceed;
      // the plan builder creates the document immediately on first load.
      allow get: if isPlatformAdmin()
                 || (resource == null && (isCoach() || isCoachByUid(planId)))
                 || (resource != null && (
                      isOwnDoc(resource.data.memberId)
                      || isCoachOrBootstrap(resource.data.coachId)
                    ));
      // list: Firestore enforces that the query must filter by coachId or memberId
      // matching the caller, preventing unscoped cross-tenant queries.
      allow list: if isAuthenticated() && (
        isPlatformAdmin()
        || isCoachOrBootstrap(resource.data.coachId)
        || isOwnDoc(resource.data.memberId)
      );
      allow create: if isCoachOrBootstrap(request.resource.data.coachId) || isPlatformAdmin();
      // update: only the owning coach (or admin) may modify a plan.
      // The broad isCoach() fallback has been removed — coaches can only update
      // plans where their UID matches the stored coachId field.
      allow update: if isPlatformAdmin()
                   || (resource != null && isCoachOrBootstrap(resource.data.coachId));
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // RULE VERSIONS (read: all authenticated; write: Cloud Functions only via Admin SDK)
    // ─────────────────────────────────────────────

    match /rule_versions/{ruleId} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions use Admin SDK (bypasses rules)
    }

    // ─────────────────────────────────────────────
    // LEDGER ENTRIES (append-only; Cloud Functions write via Admin SDK)
    // ─────────────────────────────────────────────

    match /ledger_entries/{entryId} {
      allow read: if isCoachOrBootstrap(resource.data.coachId) || isPlatformAdmin();
      allow create: if false; // Cloud Functions only
      allow update: if false; // append-only — never update
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // EARNINGS CAPS (Cloud Functions write via Admin SDK)
    // ─────────────────────────────────────────────

    match /earnings_caps/{capId} {
      allow read: if isCoachOrBootstrap(resource.data.coachId) || isPlatformAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ─────────────────────────────────────────────
    // STRIPE ACCOUNTS (Cloud Functions write via Admin SDK)
    // ─────────────────────────────────────────────

    match /stripe_accounts/{coachId} {
      allow read: if isOwnDoc(coachId) || isPlatformAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ─────────────────────────────────────────────
    // CONSENTS (member reads/writes own; Cloud Functions write on behalf)
    // ─────────────────────────────────────────────

    match /consents/{consentId} {
      allow read: if isOwnDoc(resource.data.userId)
                  || isCoachOrBootstrap(resource.data.coachId)
                  || isPlatformAdmin();
      allow create: if isOwnDoc(request.resource.data.userId);
      allow update: if isOwnDoc(resource.data.userId); // for revocation
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // VOICE PROVIDER SETTINGS (read: all authenticated; write: platformAdmin + Cloud Functions)
    // ─────────────────────────────────────────────

    match /voice_provider_settings/{profileId} {
      allow read: if isAuthenticated();
      allow create: if isPlatformAdmin();
      allow update: if isPlatformAdmin()
                    || (isCoach() && resource.data.ownerType == 'coach' && isOwnDoc(resource.data.ownerId));
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // CHECK-INS (daily habit check-ins — member writes own; coach reads tenant's)
    // ─────────────────────────────────────────────

    match /check_ins/{checkInId} {
      // Members can create their own check-ins
      allow create: if isAuthenticated()
                    && request.auth.uid == request.resource.data.uid
                    && request.resource.data.keys().hasOnly(['uid', 'date', 'completed', 'createdAt']);
      // Members read their own; coaches read their tenant's members'
      allow read: if isAuthenticated()
                  && (isOwnDoc(resource.data.uid)
                      || isCoachOrBootstrap(resource.data.coachId)
                      || isPlatformAdmin());
      // No updates or deletes — check-ins are append-only
      allow update: if false;
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // MOVEMENTS (Week 2 — coachId-scoped CRUD)
    // ─────────────────────────────────────────────

    match /movements/{movementId} {
      allow read: if isAuthenticated() && (
        resource.data.isGlobal == true ||
        isCoachOrBootstrap(resource.data.coachId)
      );
      allow create: if isCoachOrBootstrap(request.resource.data.coachId);
      allow update: if isCoachOrBootstrap(resource.data.coachId) || isPlatformAdmin();
      allow delete: if false; // archive only
    }

    // ─────────────────────────────────────────────
    // WORKOUTS (Week 3 — coachId-scoped CRUD)
    // App uses 'workouts' collection (not 'workout_templates')
    // ─────────────────────────────────────────────

    match /workouts/{workoutId} {
      // Coaches can read their own workouts, OR any workout marked isShared (template marketplace)
      allow read: if isAuthenticated() && (
        isCoachOrBootstrap(resource.data.coachId)
        || (resource.data.isShared == true && (isCoach() || isPlatformAdmin()))
      );
      allow create: if isCoachOrBootstrap(request.resource.data.coachId);
      // Only the owning coach or admin can update (including toggling isShared)
      allow update: if isCoachOrBootstrap(resource.data.coachId) || isPlatformAdmin();
      // R5: Owning coach or admin can delete any workout they own
      allow delete: if isCoachOrBootstrap(resource.data.coachId) || isPlatformAdmin();
    }

    // ─────────────────────────────────────────────
    // WORKOUT TEMPLATES (legacy alias — kept for backwards compat)
    // ─────────────────────────────────────────────

    match /workout_templates/{templateId} {
      allow read: if isAuthenticated() && isCoachOrBootstrap(resource.data.coachId);
      allow create: if isCoachOrBootstrap(request.resource.data.coachId);
      allow update: if isCoachOrBootstrap(resource.data.coachId);
      allow delete: if isCoachOrBootstrap(resource.data.coachId) || isPlatformAdmin();
    }

    // ─────────────────────────────────────────────
    // MEMBERS (Week 4 — coachId-scoped CRUD)
    // ─────────────────────────────────────────────

    match /members/{memberId} {
      allow read: if isAuthenticated() && (
        isCoachOrBootstrap(resource.data.coachId) ||
        isOwnDoc(resource.data.memberId) ||
        isOwnDoc(resource.data.uid) ||
        isPlatformAdmin()
      );
      // Coach can create members, OR a new user can create their own member doc during intake
      // IMPORTANT: Allow authenticated intake form submissions (just-created users)
      allow create: if isCoachOrBootstrap(request.resource.data.coachId)
                    || (isAuthenticated() && request.auth.uid == request.resource.data.uid
                        && request.resource.data.keys().hasOnly([
                          'uid', 'coachId', 'email', 'displayName', 'phone',
                          'gender', 'dateOfBirth', 'height', 'weight', 'createdAt', 'isArchived', 'role', 'hasAccount'
                        ]));
      // Members can update their own safe profile fields
      // Coaches can update members they own OR reassign members to themselves
      allow update: if isCoachOrBootstrap(resource.data.coachId)
                    || isPlatformAdmin()
                    || (isAuthenticated() && isOwnDoc(resource.data.uid)
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['displayName', 'phone', 'photoURL', 'updatedAt']))
                    || (isAuthenticated() && request.auth.uid == request.resource.data.coachId
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['coachId', 'updatedAt']));
      allow delete: if false; // archive only
    }

    // ─────────────────────────────────────────────
    // WORKOUT ASSIGNMENTS (Week 5 — coachId-scoped CRUD)
    // Coach can CRUD assignments scoped to their own coachId.
    // Member can read their own assignments and update status.
    // Delete is allowed for coach (unassign workflow).
    // ─────────────────────────────────────────────

    match /workout_assignments/{assignmentId} {
      allow read: if isAuthenticated() && (
        isCoachOrBootstrap(resource.data.coachId) ||
        isOwnDoc(resource.data.memberId) ||
        isPlatformAdmin()
      );
      allow create: if isCoachOrBootstrap(request.resource.data.coachId);
      allow update: if isCoachOrBootstrap(resource.data.coachId)
                    || (isAuthenticated() && isOwnDoc(resource.data.memberId)
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['status', 'completedAt', 'updatedAt']))
                    || isPlatformAdmin();
      allow delete: if isCoachOrBootstrap(resource.data.coachId) || isPlatformAdmin();
    }

    // ─────────────────────────────────────────────
    // WORKOUT LOGS (post-workout journal / completion records)
    // Members create logs for their own completed workouts.
    // Coaches read logs for their members' workouts.
    // Members can update their own logs (e.g. edit journal).
    // ─────────────────────────────────────────────

    match /workout_logs/{logId} {
      allow read: if isAuthenticated() && (
        isOwnDoc(resource.data.memberId) ||
        isCoachOrBootstrap(resource.data.coachId) ||
        isPlatformAdmin()
      );
      allow create: if isAuthenticated()
                    && request.auth.uid == request.resource.data.memberId
                    && request.resource.data.keys().hasAll(['memberId', 'coachId', 'assignmentId', 'completedAt']);
      allow update: if isAuthenticated() && (
        // Members can update their own log (edit journal entries)
        (isOwnDoc(resource.data.memberId)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['journal', 'glow', 'grow', 'rating', 'updatedAt']))
        // Coaches can add review notes
        || (isCoachOrBootstrap(resource.data.coachId)
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['coachNotes', 'coachReaction', 'reviewedAt', 'updatedAt']))
        || isPlatformAdmin()
      );
      allow delete: if false; // never delete workout logs
    }

    // ─────────────────────────────────────────────
    // REFERRALS (Cloud Functions write via Admin SDK)
    // ─────────────────────────────────────────────

    match /referrals/{referralId} {
      allow read: if isOwnDoc(resource.data.referrerId)
                  || isOwnDoc(resource.data.referredId)
                  || isPlatformAdmin();
      allow write: if false; // Cloud Functions only
    }

    match /inter_coach_referrals/{referralId} {
      allow read: if isOwnDoc(resource.data.referringCoachId)
                  || isOwnDoc(resource.data.receivingCoachId)
                  || isPlatformAdmin();
      allow write: if false; // Cloud Functions only
    }

    match /profit_share/{recordId} {
      allow read: if isOwnDoc(resource.data.coachId) || isPlatformAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ─────────────────────────────────────────────
    // SPONSOR DISCLOSURES
    // ─────────────────────────────────────────────

    match /sponsor_disclosures/{disclosureId} {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin();
    }

    // ─────────────────────────────────────────────
    // COACH STRIPE ACCOUNTS (Cloud Functions write via Admin SDK)
    // Coaches read their own account status; members never see this.
    // ─────────────────────────────────────────────

    match /coachStripeAccounts/{coachId} {
      allow read: if isOwnDoc(coachId) || isPlatformAdmin();
      allow write: if false; // Cloud Functions only (Admin SDK)
    }

    // ─────────────────────────────────────────────
    // CHECKOUT INTENTS (Cloud Functions write via Admin SDK)
    // Members read their own intent to poll status on checkout-success.
    // Coaches read intents for their members.
    // ─────────────────────────────────────────────

    match /checkoutIntents/{intentId} {
      allow read: if isAuthenticated() && (
        isOwnDoc(resource.data.memberId)
        || isCoachOrBootstrap(resource.data.coachId)
        || isPlatformAdmin()
      );
      allow write: if false; // Cloud Functions only
    }

    // ─────────────────────────────────────────────
    // MEMBER SUBSCRIPTIONS (Cloud Functions write via Admin SDK)
    // Members read their own subscription; coaches read their members'.
    // ─────────────────────────────────────────────

    match /memberSubscriptions/{subId} {
      allow read: if isAuthenticated() && (
        isOwnDoc(resource.data.memberId)
        || isCoachOrBootstrap(resource.data.coachId)
        || isPlatformAdmin()
      );
      allow write: if false; // Cloud Functions only
    }

    // ─────────────────────────────────────────────
    // BILLING EVENTS (Cloud Functions write via Admin SDK)
    // Raw Stripe webhook events — internal audit log.
    // Only platformAdmin can read; never exposed to coaches or members.
    // ─────────────────────────────────────────────

    match /billingEvents/{eventId} {
      allow read: if isPlatformAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ─────────────────────────────────────────────
    // LEDGER ENTRIES (append-only; Cloud Functions write via Admin SDK)
    // Coaches read their own entries; members never see ledger data.
    // Note: collection name is 'ledgerEntries' (camelCase) to match
    // the Cloud Functions index.ts writes. The legacy 'ledger_entries'
    // rule above is kept for backward compatibility.
    // ─────────────────────────────────────────────

    // ─────────────────────────────────────────────
    // COMMIT TO SAVE CONSENTS
    // Members create their own consent; Cloud Function updates status.
    // Coaches read consents for their members.
    // ─────────────────────────────────────────────

    match /commitToSaveConsents/{consentId} {
      // Members can create their own consent
      allow create: if isAuthenticated()
                    && request.auth.uid == request.resource.data.memberId;
      // Members read their own; coaches read their members'
      allow read: if isAuthenticated() && (
        isOwnDoc(resource.data.memberId)
        || isCoachOrBootstrap(resource.data.coachId)
        || isPlatformAdmin()
      );
      // Only Cloud Functions update status (Admin SDK bypasses rules)
      allow update: if false;
      allow delete: if false;
    }

    match /ledgerEntries/{entryId} {
      allow read: if isCoachOrBootstrap(resource.data.coachId) || isPlatformAdmin();
      allow create: if false; // Cloud Functions only
      allow update: if false; // append-only — never update
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // ZOOM ROOMS (Scheduling backbone)
    // Coach manages their own Zoom room resources.
    // Cloud Functions also write via Admin SDK.
    // ─────────────────────────────────────────────

    match /zoom_rooms/{roomId} {
      allow read: if isAuthenticated() && (
        isCoachOrBootstrap(resource.data.coachId)
        || isPlatformAdmin()
      );
      // Coaches create/update their own rooms; Cloud Functions also write via Admin SDK
      allow create: if isCoachOrBootstrap(request.resource.data.coachId) || isPlatformAdmin();
      allow update: if isCoachOrBootstrap(resource.data.coachId) || isPlatformAdmin();
      allow delete: if false; // deactivate only
    }

    // ─────────────────────────────────────────────
    // RECURRING SLOTS (Scheduling backbone)
    // Coach creates/manages recurring time slots for their members.
    // Members can read their own slots.
    // ─────────────────────────────────────────────

    match /recurring_slots/{slotId} {
      allow read: if isAuthenticated() && (
        isCoachOrBootstrap(resource.data.coachId)
        || isOwnDoc(resource.data.memberId)
        || isPlatformAdmin()
      );
      allow create: if isCoachOrBootstrap(request.resource.data.coachId) || isPlatformAdmin();
      allow update: if isCoachOrBootstrap(resource.data.coachId) || isPlatformAdmin();
      allow delete: if false; // cancel only
    }

    // ─────────────────────────────────────────────
    // SESSION INSTANCES (Scheduling backbone)
    // Concrete occurrences generated from recurring slots.
    // Coach can read/update; members can read their own.
    // Cloud Functions create via Admin SDK and scheduled functions.
    // ─────────────────────────────────────────────

    match /session_instances/{instanceId} {
      allow read: if isAuthenticated() && (
        isCoachOrBootstrap(resource.data.coachId)
        || isOwnDoc(resource.data.memberId)
        || isPlatformAdmin()
      );
      allow create: if isCoachOrBootstrap(request.resource.data.coachId) || isPlatformAdmin();
      allow update: if isCoachOrBootstrap(resource.data.coachId) || isPlatformAdmin();
      allow delete: if false; // cancel only
    }

    // ─────────────────────────────────────────────
    // SCHEDULING AUDIT LOG (Scheduling backbone)
    // Append-only audit trail for scheduling decisions.
    // Coach can read their own entries.
    // Cloud Functions write via Admin SDK.
    // ─────────────────────────────────────────────

    match /scheduling_audit_log/{entryId} {
      allow read: if isAuthenticated() && (
        isCoachOrBootstrap(resource.data.coachId)
        || isPlatformAdmin()
      );
      allow create: if false; // Cloud Functions only (Admin SDK)
      allow update: if false; // append-only
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // SESSION EVENTS (Scheduling — per-instance event log)
    // Append-only event trail for session lifecycle.
    // Coach reads own; admin reads all.
    // Cloud Functions write via Admin SDK.
    // ─────────────────────────────────────────────

    match /session_events/{eventId} {
      allow read: if isAuthenticated() && (
        isCoachOrBootstrap(resource.data.coachId)
        || isPlatformAdmin()
      );
      allow create: if false; // Cloud Functions only (Admin SDK)
      allow update: if false; // append-only
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // REMINDER JOBS (Scheduling — notification reminders)
    // Cloud Functions create, process, and update.
    // No client-side access needed.
    // ─────────────────────────────────────────────

    match /reminder_jobs/{jobId} {
      allow read: if isPlatformAdmin();
      allow write: if false; // Cloud Functions only (Admin SDK)
    }

    // ─────────────────────────────────────────────
    // DEAD LETTER (Scheduling — failed notification/reminder items)
    // Cloud Functions write; admin reads for retry.
    // ─────────────────────────────────────────────

    match /dead_letter/{itemId} {
      allow read: if isPlatformAdmin();
      allow write: if false; // Cloud Functions only (Admin SDK)
    }

    // ─────────────────────────────────────────────
    // NOTIFICATION LOG (Scheduling — sent notification records)
    // Cloud Functions write; admin reads for diagnostics.
    // ─────────────────────────────────────────────

    match /notification_log/{logId} {
      allow read: if isPlatformAdmin();
      allow write: if false; // Cloud Functions only (Admin SDK)
    }

    // ─────────────────────────────────────────────
    // COACH ZOOM CONNECTIONS (Scheduling — personal Zoom linkage)
    // Coach reads/writes their own connection.
    // Admin reads all for diagnostics.
    // ─────────────────────────────────────────────

    match /coach_zoom_connections/{coachId} {
      allow read: if isOwnDoc(coachId) || isPlatformAdmin();
      allow create: if isOwnDoc(coachId);
      allow update: if isOwnDoc(coachId);
      allow delete: if isOwnDoc(coachId); // disconnect flow
    }

    // ─────────────────────────────────────────────
    // COACH APPLICATIONS (public form — no auth required)
    // Anyone can submit an application; only admins can read/update.
    // ─────────────────────────────────────────────

    match /coachApplications/{applicationId} {
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll(['firstName', 'lastName', 'email', 'status', 'createdAt'])
        && request.resource.data.keys().hasOnly([
          'firstName', 'lastName', 'dateOfBirth', 'streetAddress', 'streetAddress2',
          'city', 'state', 'zipCode', 'phone', 'email', 'igHandle', 'facebookHandle',
          'currentOccupation', 'employmentStatus', 'otherEmploymentStatus',
          'maintainEmployment', 'employerName', 'employerWebsite',
          'certifications', 'yearsExperience', 'specializations',
          'topThreeStrengths', 'weakness', 'standOut', 'idealMember',
          'numberOneGoal', 'supportFromTeamLead', 'desiredMonthlyEarnings',
          'whyJoinGoArrive', 'greatFit',
          'entrepreneurialSpirit', 'teamPlayer', 'adaptability', 'communicationSkills',
          'howHeardAbout', 'otherHowHeard', 'referringCoachName',
          'weeklyHoursAvailable', 'weekendAvailability', 'availability',
          'resumeUrl', 'resumeFileName', 'certificationsUrl', 'certificationsFileName',
          'futureResume',
          'futureResumeVideoUrl', 'futureResumeVideoFileName',
          'ref1Name', 'ref1Email', 'ref1Phone',
          'ref2Name', 'ref2Email', 'ref2Phone',
          'ref3Name', 'ref3Email', 'ref3Phone',
          'truthAcknowledged', 'signatureName', 'signatureDate',
          'status', 'createdAt'
        ]);
      allow read, update: if isPlatformAdmin();
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // CATCH-ALL: deny everything else
    // ─────────────────────────────────────────────

    // ─────────────────────────────────────────────
    // INTAKE SUBMISSIONS (unauthenticated form submissions)
    // ─────────────────────────────────────────────

    match /intakeSubmissions/{submissionId} {
      // Allow unauthenticated users, just-created users, or coaches to submit intake forms
      allow create: if request.auth == null
                    || (isAuthenticated() && request.auth.uid == request.resource.data.uid)
                    || (isAuthenticated() && isCoachOrBootstrap(request.resource.data.coachId));
      // get: full document-level check (resource.data available)
      allow get: if isAuthenticated() && isCoachOrBootstrap(resource.data.coachId);
      // list: require the query to scope to the caller's coachId.
      // The app only uses get (single doc reads), so list is admin/coach-only.
      allow list: if isAuthenticated() && (
        isPlatformAdmin()
        || isCoachOrBootstrap(resource.data.coachId)
      );
      allow update: if isAuthenticated() && isCoachOrBootstrap(resource.data.coachId);
      allow delete: if false;
    }

     // ─────────────────────────────────────────────
    // NOTIFICATIONS
    // ─────────────────────────────────────────────
    match /notifications/{notifId} {
      // Only coaches can create notifications for their members
      allow create: if isAuthenticated()
                    && (isCoach() || isCoachByUid(request.resource.data.coachId) || isPlatformAdmin());
      // Members can read and mark their own notifications as read
      allow read, update: if isAuthenticated() && request.auth.uid == resource.data.recipientId;
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // COACH INVITES (Admin reads pending invites)
    // Cloud Functions create/update via Admin SDK.
    // ─────────────────────────────────────────────

    match /coachInvites/{inviteId} {
      allow read: if isPlatformAdmin();
      allow write: if false; // Cloud Functions only (Admin SDK)
    }

    // ─────────────────────────────────────────────
    // EVENT LOG (Admin audit trail)
    // Admins can read and write audit events.
    // ─────────────────────────────────────────────

    match /eventLog/{eventId} {
      allow read: if isPlatformAdmin();
      allow create: if isAuthenticated() && isPlatformAdmin();
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────
    // CTS ACCOUNTABILITY FEES
    // Readable by the member, their coach, or admin.
    // Writable only by Cloud Functions (Admin SDK).
    // ─────────────────────────────────────────────

    match /ctsAccountabilityFees/{feeId} {
      allow read: if isPlatformAdmin()
                  || isOwnDoc(resource.data.memberId)
                  || isCoachOrBootstrap(resource.data.coachId);
      allow write: if false; // Cloud Functions only (Admin SDK)
    }

    // ─────────────────────────────────────────────
    // NOTIFICATION COOLDOWNS (Cloud Functions only — deny all client access)
    // Written by rate-limiting logic in onWorkoutAssigned / onWorkoutCompleted.
    // Cleaned up by cleanupNotificationCooldowns scheduled function.
    // ─────────────────────────────────────────────

    match /_notification_cooldowns/{docId} {
      allow read, write: if false;
    }

    // _system_health: server-only monitoring data (cleanup status, health checks)
    match /_system_health/{docId} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────
    // ACCEPTED PLAN SNAPSHOTS (Cloud Functions only — immutable)
    // Created at checkout time by createCheckoutSession. Contains locked-in
    // pricing, tier split, and contract terms. MUST NOT be modified after
    // creation — all revenue calculations reference this snapshot.
    // ─────────────────────────────────────────────
    match /acceptedPlanSnapshots/{snapshotId} {
      // Coaches and admins can read their own snapshots for auditing
      allow read: if isAuthenticated() && (
        isPlatformAdmin() ||
        isCoachByUid(resource.data.coachId)
      );
      // No client writes — only Cloud Functions (Admin SDK) can create
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
