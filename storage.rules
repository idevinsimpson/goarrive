rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Platform voice cues — publicly readable (no auth required)
    match /voice_cache/platform/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    // Coach voice clones — readable by authenticated users only
    match /voice_cache/coaches/{coachId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Movement media — scoped to coach
    match /movements/{coachId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == coachId;
    }

    // Coach application uploads — public write (no auth), admin-only read
    match /coachApplications/{fileName} {
      allow write: if request.resource.size < 200 * 1024 * 1024;
      allow read: if request.auth != null;
    }

    // Fallback: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
