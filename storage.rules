rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Platform voice cues — publicly readable (no auth required)
    match /voice_cache/platform/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    // OpenAI TTS generated cues — publicly readable (generated audio, no PII)
    match /voice_cache/tts/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    // Movement voice clips — publicly readable (generated audio, no PII)
    match /voice_cache/movements/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    // Combined cue phrases (e.g. "Next up, Barbell Curl.") — publicly readable
    match /voice_cache/phrases/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    // Coach voice clones — readable by authenticated users only
    match /voice_cache/coaches/{coachId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Movement media — scoped to coach
    match /movements/{coachId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == coachId;
    }

    // Coach application uploads — public write (no auth), public read
    // Write: unauthenticated, capped at 500 MB (2-3 min phone video at any quality)
    // Read: unauthenticated so getDownloadURL() works from the public form.
    //   Security is token-based: download URLs include a random token,
    //   and the URLs are only stored in Firestore (admin-only read).
    //   Paths use timestamps making enumeration impractical.
    match /coachApplications/{allPaths=**} {
      allow write: if request.resource.size < 500 * 1024 * 1024;
      allow read: if true;
    }

    // Workout media (intro/outro videos) — scoped to coach
    match /workouts/{coachId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == coachId;
    }

    // Fallback: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
