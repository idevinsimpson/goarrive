{
  "expo": {
    "name": "GoArrive",
    "slug": "goarrive",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/goarrive-icon.png",
    "scheme": "goarrive",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.goarrive.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E1117"
      },
      "package": "com.goarrive.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/goarrive-icon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}