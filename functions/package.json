{
  "name": "goarrive-functions",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test:rules": "jest --rootDir=.. --testPathPattern='firestore\\.rules\\.test'",
    "test:src": "node --max-old-space-size=4096 ./node_modules/jest/bin/jest.js --config jest.config.src.js"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/../firestore.rules.test.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "module": "commonjs",
          "esModuleInterop": true
        }
      }
    }
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/functions-framework": "^5.0.2",
    "@google-cloud/tasks": "^6.2.1",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^4.9.0",
    "googleapis": "^171.4.0",
    "stripe": "^20.4.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "private": true
}
